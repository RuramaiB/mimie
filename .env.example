# ═══════════════════════════════════════════════════════
#  SECURITY & AUTHENTICATION (FastAPI JWT)
# ═══════════════════════════════════════════════════════
SECRET_KEY=generate_your_own_secure_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ═══════════════════════════════════════════════════════
#  DATABASE CONNECTIONS
# ═══════════════════════════════════════════════════════

# MySQL 8
MYSQL_HOST=mysql-db
MYSQL_PORT=3306
MYSQL_USER=land_app
MYSQL_PASSWORD=your_app_password
MYSQL_DB=devdb
MYSQL_ADMIN_USER=admin
MYSQL_ADMIN_PASSWORD=your_admin_password

# PostgreSQL + PostGIS
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
POSTGRES_USER=land_app
POSTGRES_PASSWORD=your_app_password
POSTGRES_DB=devdb
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=your_admin_password

# Oracle XE
ORACLE_HOST=oracle-db
ORACLE_PORT=1521
ORACLE_USER=land_app
ORACLE_PASSWORD=your_app_password
ORACLE_SERVICE=XE
ORACLE_ADMIN_USER=admin
ORACLE_ADMIN_PASSWORD=your_admin_password

# MS SQL Server 2022
MSSQL_HOST=mssql-db
MSSQL_PORT=1433
MSSQL_USER=land_app
MSSQL_PASSWORD=your_app_password
MSSQL_DB=devdb
MSSQL_ADMIN_USER=sa
MSSQL_ADMIN_PASSWORD=your_admin_password

# MongoDB 7
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=land_app
MONGO_PASSWORD=your_app_password
MONGO_DB=devdb
MONGO_AUTH_DB=admin
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASSWORD=your_admin_password

# MongoDB Atlas Sync URI
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/devdb?retryWrites=true&w=majority
