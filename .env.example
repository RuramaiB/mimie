# ═══════════════════════════════════════════════════════
#  SECURITY & AUTHENTICATION (FastAPI JWT)
# ═══════════════════════════════════════════════════════
SECRET_KEY=generate_your_own_secure_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ═══════════════════════════════════════════════════════
#  DATABASE CONNECTIONS
# ═══════════════════════════════════════════════════════

# MySQL 8
MYSQL_HOST=mysql-c
MYSQL_PORT=3306
MYSQL_USER=melissa
MYSQL_PASSWORD=admin@melissa
MYSQL_DB=melissa-db
MYSQL_ADMIN_USER=melissa
MYSQL_ADMIN_PASSWORD=admin@melissa

# PostgreSQL + PostGIS
POSTGRES_HOST=postgres-c
POSTGRES_PORT=5432
POSTGRES_USER=melissa
POSTGRES_PASSWORD=admin@melissa
POSTGRES_DB=melissa-db
POSTGRES_ADMIN_USER=melissa
POSTGRES_ADMIN_PASSWORD=admin@melissa

# Oracle XE
ORACLE_HOST=oracle-c
ORACLE_PORT=1521
ORACLE_USER=melissa
ORACLE_PASSWORD=admin@melissa
ORACLE_SERVICE=melissadb
ORACLE_ADMIN_USER=melissa
ORACLE_ADMIN_PASSWORD=admin@melissa

# MS SQL Server 2022
MSSQL_HOST=mssql-c
MSSQL_PORT=1433
MSSQL_USER=melissa
MSSQL_PASSWORD=admin@melissa
MSSQL_DB=melissa-db
MSSQL_ADMIN_USER=sa
MSSQL_ADMIN_PASSWORD=Admin@melissa123

# MongoDB 7
MONGO_HOST=mongodb-c
MONGO_PORT=27017
MONGO_USER=melissa
MONGO_PASSWORD=admin@melissa
MONGO_DB=melissa-db
MONGO_AUTH_DB=admin
MONGO_ADMIN_USER=melissa
MONGO_ADMIN_PASSWORD=admin@melissa

# MongoDB Atlas Sync URI
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/devdb?retryWrites=true&w=majority
